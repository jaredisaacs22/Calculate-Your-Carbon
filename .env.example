# Copy this file to .env and fill in real values before running docker-compose

# PostgreSQL password (used by both postgres service and backend)
DB_PASSWORD=changeme

# Secret key for any signed tokens / admin auth
SECRET_KEY=change-this-to-a-long-random-string

# Scraper identity sent in User-Agent headers
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; CarbonCalcBot/1.0)

# Fuel price defaults (can be overridden per request)
DEFAULT_DIESEL_PRICE_USD_PER_LITER=1.35
